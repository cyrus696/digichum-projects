        </select>
        
      </div>
    </div>

   
    <div class="overlay" id="overlay" onclick="closeSearchPanel()"></div>

    <!-- SEARCH MEGA MENU -->
    <div class="search-panel" id="searchPanel">

      <div class="search-panel-header">
        <input type="text" placeholder="Search by location, project, keyword..." autofocus />
        <span class="close-btn" onclick="closeSearchPanel()">✕</span>
      </div>

      <div class="search-content">
        <div class="column">
          <h4>For Rent</h4>
          <ul>
            <li>1 BHK</li>
            <li>2 BHK</li>
            <li>3 BHK</li>
            <li>Flats</li>
            <li>Offices</li>
            <li>Floors</li>
          </ul>
        </div>

        <div class="column">
          <h4>To Buy</h4>
          <ul>
            <li>Flats</li>
            <li>Villas</li>
            <li>Homes</li>
            <li>Farmhouses</li>
            <li>Plots</li>
          </ul>
        </div>

        <div class="column">
          <h4>Sell</h4>
          <ul>
            <li>Flats</li>
            <li>Homes</li>
            <li>Farmhouses</li>
            <li>Plots</li>
            <li>Lands</li>
            <li>Office</li>
          </ul>
        </div>

        <div class="column">
          <h4>For Builders / Dealers</h4>
          <ul>
            <li>Post Property</li>
            <li>Dealer Services</li>
          </ul>
        </div>
      </div>

    </div>
  </section>


  <div class="info-section">
    <div class="info-content">
      <h2>Luxury Lives Here</h2>
      <p>
        With over 25 years in the industry, Dwello Real Estate has a wealth of knowledge and experience in Barbados'
        luxury real estate market. Known for delivering outstanding results, Stewart & Co Real Estate has earned a
        reputation synonymous with reliability, honesty and transparency, helping clients buy and sell property with
        exceptional dedication and expertise.
      </p>
    </div>
  </div>
  </section>

  <!-- PROJECTS SECTION -->
  <section class="projects-section">
    <!-- Item 1 -->
    <div class="project-item">
      <div class="project-bg"
        style="background-image: url('/Sources/Images/Main\ pg\ 3rd\ img.jpg');"></div>
      <div class="project-content right">
        <h2>Luxury living, brought to life<br> &larr; by us</h2>
      </div>
    </div>

    <!-- Item 2 -->
    <div class="project-item">
      <div class="project-bg"
        style="background-image: url('/Sources/Images/Main\ pg\ 5th\ img.jpg');"></div>
      <div class="project-content left">
        <h2>Projects that define modern<br>living &rarr;</h2>
      </div>
    </div>

    <!-- Item 3 -->
    <div class="project-item">
      <div class="project-bg" style="background-image: url('/Sources/Images/Main\ pg\ 4th\ img.jpg');">
      </div>
      <div class="project-content right">
        <h2>Luxury that feels calm, minimal<br>&larr; and indulgent</h2>
      </div>
    </div>
  </section>

   <!-- NEWSLETTER SECTION -->
   <section id="Contact-us" class="newsletter-section">
    <div class="newsletter-content">
      <h2>Keep yourself updated on the latest luxury<br>property available</h2>

      <form class="newsletter-form">
        <input type="text" placeholder="Name*" required />
        <input type="email" placeholder="Email*" required />
        <input type="tel" placeholder="Phone" />
      </form>

      <div class="newsletter-checkbox">
        <input type="checkbox" id="consent" />
        <label for="consent">
          By providing your contact information, you acknowledge and agree to Dwello Homes' Privacy
          Policy and consent to receiving marketing communications, including automated calls, texts,
          and emails. Consent is not a condition of purchase. You may opt out at any time.
        </label>
