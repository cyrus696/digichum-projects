          <option>Shops</option>
        </select>
        <select>
          <option>Resenditials</option>
          <option>1bhk</option>
          <option>2Bhk</option>
          <option>3Bhk</option>
          <option>4Bhk</option>
          <option>Flats</option>
          <option>Plots</option>
          <option>Houses/Homes</option>
        </select>
        <select>
          <option>Price Range</option>
          <option>₹50,000 - ₹1,00,000</option>
          <option>₹1,00,000 - ₹5,00,000</option>
